# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET=your-random-secret-min-32-chars          # openssl rand -base64 32
AUTH_ADMIN_EMAIL=admin@example.com

# Password — choose one of the two options below:
#
# Option 1 (local dev only): plain text, compared directly
AUTH_ADMIN_PASSWORD_PLAIN=your-admin-password
#
# Option 2 (production): bcrypt hash — comment out the line above and use this instead
# Generate with: node -e "import('bcryptjs').then(m => m.hash('yourpassword', 12).then(console.log))"
# AUTH_ADMIN_PASSWORD=$2b$12$examplehashedvaluehere

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=PureBlog

# ─── Email (Gmail) ────────────────────────────────────────────────────────────
# Required for: comment notifications, newsletter, contact replies
# Use an App Password (not your regular password):
# Google Account → Security → 2FA → App Passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Cloudinary (Image Uploads) ───────────────────────────────────────────────
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Cron (Scheduled Posts) ───────────────────────────────────────────────────
# Set this on Vercel and add the same value to vercel.json cron headers
# Any random string works: openssl rand -hex 16
CRON_SECRET=your-cron-secret
